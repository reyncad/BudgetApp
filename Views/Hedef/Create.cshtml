@model BudgetApp.Models.Hedef
@{
    ViewData["Title"] = "Yeni Hedef";
}

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
        <div class="mb-4">
            <div class="text-muted" style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.8px">Tasarruf Planı</div>
            <div style="font-size:20px;font-weight:700;color:#1e293b">Yeni Hedef Ekle</div>
        </div>
        <div class="card">
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Ad" class="form-label"></label>
                        <input asp-for="Ad" class="form-control" placeholder="Örn: Tatil fonu, Araba, Laptop..." />
                        <span asp-validation-for="Ad" class="text-danger" style="font-size:12px"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Aciklama" class="form-label"></label>
                        <input asp-for="Aciklama" class="form-control" placeholder="İsteğe bağlı not..." />
                    </div>

                    <div class="mb-3">
                        <label asp-for="HedefMiktar" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="HedefMiktar" class="form-control" type="number" step="0.01" min="1" placeholder="0,00" />
                            <span class="input-group-text">₺</span>
                        </div>
                        <span asp-validation-for="HedefMiktar" class="text-danger" style="font-size:12px"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BirikmisMiktar" class="form-label">Şu An Birikmiş (₺)</label>
                        <div class="input-group">
                            <input asp-for="BirikmisMiktar" class="form-control" type="number" step="0.01" min="0" placeholder="0,00" />
                            <span class="input-group-text">₺</span>
                        </div>
                        <div class="form-text">Zaten biriktirdiğin varsa gir, yoksa 0 bırak.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="HedefTarihi" class="form-label"></label>
                        <input asp-for="HedefTarihi" class="form-control" type="date" />
                        <div class="form-text">İsteğe bağlı — ne zaman ulaşmak istiyorsun?</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">Hedef Oluştur</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
