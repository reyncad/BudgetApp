@model IEnumerable<BudgetApp.Models.Kategori>
@{
    ViewData["Title"] = "Bütçe";
    var tr = new System.Globalization.CultureInfo("tr-TR");
    int ay  = ViewBag.SecilenAy;
    int yil = ViewBag.SecilenYil;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="text-muted" style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.8px">
            @(new DateTime(yil, ay, 1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")))
        </div>
        <div style="font-size:20px;font-weight:700;color:#1e293b">Aylık Bütçe</div>
    </div>
    <form method="get" class="d-flex gap-2">
        <select name="ay" class="form-select form-select-sm" style="width:130px" onchange="this.form.submit()">
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m" selected="@(m == ay)">@(new DateTime(2000,m,1).ToString("MMMM", new System.Globalization.CultureInfo("tr-TR")))</option>
            }
        </select>
        <select name="yil" class="form-select form-select-sm" style="width:88px" onchange="this.form.submit()">
            @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
            {
                <option value="@y" selected="@(y == yil)">@y</option>
            }
        </select>
    </form>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Kategori Limitleri</span>
        <span class="text-muted" style="font-size:12px;font-weight:400">Her kategori için aylık harcama limiti belirle</span>
    </div>
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th style="width:30%">Kategori</th>
                    <th class="text-end" style="width:20%">Bu Ay Harcandı</th>
                    <th style="width:25%">Aylık Limit</th>
                    <th style="width:25%">Durum</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var k in Model)
                {
                    decimal harcanan = k.Harcamalar.Sum(h => h.Miktar);
                    int oran = k.AylikLimit.HasValue && k.AylikLimit.Value > 0
                        ? (int)Math.Min(100, harcanan / k.AylikLimit.Value * 100)
                        : 0;
                    string renk = oran >= 100 ? "#ef4444" : oran >= 75 ? "#f59e0b" : "#10b981";

                    <tr>
                        <td style="font-weight:600;vertical-align:middle">@k.Ad</td>
                        <td class="text-end" style="vertical-align:middle;font-weight:700;color:#ef4444">
                            @(harcanan.ToString("C0", tr))
                        </td>
                        <td style="vertical-align:middle">
                            <form asp-action="LimitGuncelle" asp-route-id="@k.Id" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text" style="font-size:12px">₺</span>
                                    <input type="number" name="aylikLimit"
                                           value="@(k.AylikLimit.HasValue ? k.AylikLimit.Value.ToString("F0") : "")"
                                           class="form-control" step="100" min="0"
                                           placeholder="Limit yok" style="font-size:12px" />
                                </div>
                                <button type="submit" class="btn btn-sm btn-primary" style="white-space:nowrap;font-size:11px">Kaydet</button>
                            </form>
                        </td>
                        <td style="vertical-align:middle">
                            @if (k.AylikLimit.HasValue)
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:6px">
                                        <div class="progress-bar" style="width:@(oran)%;background:@renk;border-radius:99px"></div>
                                    </div>
                                    <span style="font-size:11px;font-weight:700;color:@renk;min-width:32px">%@oran</span>
                                    @if (oran >= 100)
                                    {
                                        <span class="badge" style="background:#fef2f2;color:#ef4444;font-size:10px">Aşıldı</span>
                                    }
                                    else if (oran >= 75)
                                    {
                                        <span class="badge" style="background:#fffbeb;color:#f59e0b;font-size:10px">Dikkat</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size:12px">Limit belirlenmedi</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="alert mt-3" style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:10px;color:#0369a1;font-size:13px">
    <i class="bi bi-info-circle me-2"></i>
    Limit belirlemek için kutuya tutar gir ve <strong>Kaydet</strong>'e bas. Limiti kaldırmak için kutuyu boş bırak ve kaydet.
</div>
