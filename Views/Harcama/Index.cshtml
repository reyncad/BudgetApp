@model IEnumerable<BudgetApp.Models.Harcama>
@{
    ViewData["Title"] = "Harcamalar";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h6 class="card-title text-muted">Toplam Harcama</h6>
                    <h3 class="text-danger">@ViewBag.ToplamHarcama.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h6 class="card-title text-muted">Bu Ay</h6>
                    <h3 class="text-warning">@ViewBag.BuAyHarcama.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 d-flex align-items-center justify-content-center">
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-lg"></i> Yeni Harcama
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Harcama Listesi</h5>
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <p>Henüz harcama kaydı yok.</p>
                    <a asp-action="Create" class="btn btn-sm btn-outline-primary">İlk harcamayı ekle</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tarih</th>
                                <th>Açıklama</th>
                                <th>Kategori</th>
                                <th class="text-end">Miktar</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in Model)
                            {
                                <tr>
                                    <td>@h.Tarih.ToString("dd.MM.yyyy")</td>
                                    <td>@h.Açıklama</td>
                                    <td><span class="badge bg-secondary">@h.Kategori?.Ad</span></td>
                                    <td class="text-end fw-bold text-danger">@h.Miktar.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                                    <td class="text-center">
                                        <a asp-action="Edit" asp-route-id="@h.Id" class="btn btn-sm btn-outline-primary me-1">Düzenle</a>
                                        <a asp-action="Delete" asp-route-id="@h.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
