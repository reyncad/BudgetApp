@model BudgetApp.Models.Harcama
@{
    ViewData["Title"] = "Harcama Sil";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Harcamayı Sil</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Bu harcamayı silmek istediğinizden emin misiniz?</p>
                    <dl class="row">
                        <dt class="col-sm-4">Açıklama</dt>
                        <dd class="col-sm-8">@Model.Açıklama</dd>
                        <dt class="col-sm-4">Miktar</dt>
                        <dd class="col-sm-8 text-danger fw-bold">@Model.Miktar.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</dd>
                        <dt class="col-sm-4">Tarih</dt>
                        <dd class="col-sm-8">@Model.Tarih.ToString("dd.MM.yyyy")</dd>
                        <dt class="col-sm-4">Kategori</dt>
                        <dd class="col-sm-8">@Model.Kategori?.Ad</dd>
                    </dl>
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">Evet, Sil</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
