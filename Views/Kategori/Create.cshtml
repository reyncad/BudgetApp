@model BudgetApp.Models.Kategori
@{
    ViewData["Title"] = "Yeni Kategori";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0 fw-semibold">Yeni Kategori Ekle</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Ad" class="form-label fw-medium"></label>
                            <input asp-for="Ad" class="form-control" placeholder="Kategori adı girin" />
                            <span asp-validation-for="Ad" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="AylikLimit" class="form-label fw-medium"></label>
                            <div class="input-group">
                                <input asp-for="AylikLimit" class="form-control" type="number" step="0.01" min="0" placeholder="Boş bırakırsanız limit yok" />
                                <span class="input-group-text">₺</span>
                            </div>
                            <div class="form-text">Aylık harcama limitini aşınca uyarı alırsınız.</div>
                            <span asp-validation-for="AylikLimit" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
