@model BudgetApp.Models.Kategori
@{
    ViewData["Title"] = "Kategori Sil";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Kategoriyi Sil</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Bu kategoriyi silmek istediğinizden emin misiniz?</p>
                    @if (Model.Harcamalar.Any())
                    {
                        <div class="alert alert-warning">
                            Bu kategoriye bağlı <strong>@Model.Harcamalar.Count</strong> harcama kaydı var. Silmeden önce bu harcamaları silin veya başka bir kategoriye taşıyın.
                        </div>
                    }
                    <dl class="row">
                        <dt class="col-sm-4">Kategori Adı</dt>
                        <dd class="col-sm-8">@Model.Ad</dd>
                        <dt class="col-sm-4">Harcama Sayısı</dt>
                        <dd class="col-sm-8">@Model.Harcamalar.Count</dd>
                    </dl>
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger" @(Model.Harcamalar.Any() ? "disabled" : "")>Evet, Sil</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
