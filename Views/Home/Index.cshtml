@{
    ViewData["Title"] = "Dashboard";
    var tr = new System.Globalization.CultureInfo("tr-TR");
    decimal gelir   = ViewBag.ToplamGelir;
    decimal harcama = ViewBag.ToplamHarcama;
    decimal net     = ViewBag.NetBakiye;
    int ay  = ViewBag.SecilenAy;
    int yil = ViewBag.SecilenYil;
}

<div class="container-fluid px-2">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-semibold">
            <i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard
        </h4>
        <form method="get" class="d-flex gap-2 align-items-center">
            <select name="ay" class="form-select form-select-sm" style="width:130px" onchange="this.form.submit()">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m" selected="@(m == ay)">
                        @(new DateTime(2000, m, 1).ToString("MMMM", new System.Globalization.CultureInfo("tr-TR")))
                    </option>
                }
            </select>
            <select name="yil" class="form-select form-select-sm" style="width:90px" onchange="this.form.submit()">
                @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
                {
                    <option value="@y" selected="@(y == yil)">@y</option>
                }
            </select>
        </form>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3">
                        <i class="bi bi-arrow-down-circle-fill text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Toplam Gelir</div>
                        <div class="fs-5 fw-bold text-success">@gelir.ToString("C0", tr)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                        <i class="bi bi-arrow-up-circle-fill text-danger fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Toplam Harcama</div>
                        <div class="fs-5 fw-bold text-danger">@harcama.ToString("C0", tr)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle @(net >= 0 ? "bg-primary" : "bg-warning") bg-opacity-10 p-3">
                        <i class="bi bi-wallet-fill @(net >= 0 ? "text-primary" : "text-warning") fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Net Bakiye</div>
                        <div class="fs-5 fw-bold @(net >= 0 ? "text-primary" : "text-warning")">@net.ToString("C0", tr)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0">
                    <h6 class="fw-semibold">Son 6 Ay — Gelir / Gider Trendi</h6>
                </div>
                <div class="card-body">
                    <canvas id="trendChart" height="120"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0">
                    <h6 class="fw-semibold">Kategori Dağılımı</h6>
                </div>
                <div class="card-body d-flex justify-content-center align-items-center">
                    @{
                        var katData = (System.Collections.IEnumerable)ViewBag.KategoriHarcama;
                        bool katVar = false;
                        foreach (var _ in katData) { katVar = true; break; }
                    }
                    @if (katVar)
                    {
                        <canvas id="pieChart"></canvas>
                    }
                    else
                    {
                        <p class="text-muted text-center small">Bu ay harcama yok.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    @{
        var limitler = (System.Collections.IEnumerable)ViewBag.LimitDurumu;
        bool limitVar = false;
        foreach (var _ in limitler) { limitVar = true; break; }
    }
    @if (limitVar)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-semibold">Bütçe Limitleri</h6>
            </div>
            <div class="card-body">
                @foreach (var k in (IEnumerable<dynamic>)ViewBag.LimitDurumu)
                {
                    string renk = k.Oran >= 100 ? "danger" : k.Oran >= 80 ? "warning" : "success";
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small fw-medium">@k.Ad</span>
                            <span class="small text-muted">
                                @((decimal)k.Harcanan).ToString("C0", tr) / @((decimal)k.Limit).ToString("C0", tr)
                                @if (k.Oran >= 100) { <text><span class="badge bg-danger ms-1">Aşıldı!</span></text> }
                                else if (k.Oran >= 80) { <text><span class="badge bg-warning text-dark ms-1">Dikkat</span></text> }
                            </span>
                        </div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar bg-@renk" style="width:@k.Oran%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="row g-3">
        <div class="col-md-6">
            <a asp-controller="Harcama" asp-action="Create" class="card border-0 shadow-sm text-decoration-none text-dark">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                        <i class="bi bi-plus-circle text-danger fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Harcama Ekle</div>
                        <div class="text-muted small">Yeni bir gider kaydet</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </div>
            </a>
        </div>
        <div class="col-md-6">
            <a asp-controller="Gelir" asp-action="Create" class="card border-0 shadow-sm text-decoration-none text-dark">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3">
                        <i class="bi bi-plus-circle text-success fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Gelir Ekle</div>
                        <div class="text-muted small">Maaş, freelance, kira...</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </div>
            </a>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    const trendData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AylikOzet));
    new Chart(document.getElementById('trendChart'), {
        type: 'bar',
        data: {
            labels: trendData.map(d => d.Etiket),
            datasets: [
                { label: 'Gelir', data: trendData.map(d => d.Gelir), backgroundColor: 'rgba(25,135,84,0.75)', borderRadius: 6 },
                { label: 'Harcama', data: trendData.map(d => d.Harcama), backgroundColor: 'rgba(220,53,69,0.75)', borderRadius: 6 }
            ]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'top' } },
            scales: { y: { beginAtZero: true, ticks: { callback: v => '₺' + v.toLocaleString('tr-TR') } } }
        }
    });

    @if (katVar)
    {
        <text>
        const pieData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.KategoriHarcama));
        const colors = ['#0d6efd','#dc3545','#198754','#ffc107','#0dcaf0','#6f42c1','#fd7e14','#20c997','#adb5bd'];
        new Chart(document.getElementById('pieChart'), {
            type: 'doughnut',
            data: {
                labels: pieData.map(d => d.Ad),
                datasets: [{ data: pieData.map(d => d.Toplam), backgroundColor: colors, borderWidth: 2 }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } },
                    tooltip: { callbacks: { label: ctx => ' ₺' + ctx.parsed.toLocaleString('tr-TR') } }
                }
            }
        });
        </text>
    }
</script>
}
