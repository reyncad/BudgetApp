@{
    ViewData["Title"] = "Dashboard";
    var tr = new System.Globalization.CultureInfo("tr-TR");
    decimal gelir   = ViewBag.ToplamGelir;
    decimal harcama = ViewBag.ToplamHarcama;
    decimal net     = ViewBag.NetBakiye;
    int ay  = ViewBag.SecilenAy;
    int yil = ViewBag.SecilenYil;
    string netClass = net >= 0 ? "net-pozitif" : "net-negatif";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="text-muted" style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.8px">
            @(new DateTime(yil, ay, 1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")))
        </div>
        <div style="font-size:20px;font-weight:700;color:#1e293b">Finansal Özet</div>
    </div>
    <form method="get" class="d-flex gap-2">
        <select name="ay" class="form-select form-select-sm" style="width:130px" onchange="this.form.submit()">
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m" selected="@(m == ay)">@(new DateTime(2000,m,1).ToString("MMMM", new System.Globalization.CultureInfo("tr-TR")))</option>
            }
        </select>
        <select name="yil" class="form-select form-select-sm" style="width:88px" onchange="this.form.submit()">
            @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
            {
                <option value="@y" selected="@(y == yil)">@y</option>
            }
        </select>
    </form>
</div>

<!-- Stat cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card gelir">
            <div class="stat-icon"><i class="bi bi-arrow-down-left-circle"></i></div>
            <div class="stat-label">Toplam Gelir</div>
            <div class="stat-value">@(gelir.ToString("C0", tr))</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card harcama">
            <div class="stat-icon"><i class="bi bi-arrow-up-right-circle"></i></div>
            <div class="stat-label">Toplam Harcama</div>
            <div class="stat-value">@(harcama.ToString("C0", tr))</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card @netClass">
            <div class="stat-icon"><i class="bi bi-wallet2"></i></div>
            <div class="stat-label">Net Bakiye</div>
            <div class="stat-value">@(net.ToString("C0", tr))</div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">Son 6 Ay Trendi</div>
            <div class="card-body">
                <canvas id="trendChart" height="130"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">Kategori Dağılımı</div>
            <div class="card-body d-flex justify-content-center align-items-center" style="min-height:200px">
                @{
                    var katList = (System.Collections.IEnumerable)ViewBag.KategoriHarcama;
                    bool katVar = false;
                    foreach (var _ in katList) { katVar = true; break; }
                }
                @if (katVar)
                {
                    <canvas id="pieChart" height="180"></canvas>
                }
                else
                {
                    <div class="text-center text-muted small">
                        <i class="bi bi-pie-chart" style="font-size:36px;opacity:.3;display:block;margin-bottom:8px"></i>
                        Bu ay harcama yok
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Bütçe limitleri -->
@{
    var limitList = (System.Collections.IEnumerable)ViewBag.LimitDurumu;
    bool limitVar = false;
    foreach (var _ in limitList) { limitVar = true; break; }
}
@if (limitVar)
{
    <div class="card mb-4">
        <div class="card-header">Bütçe Limitleri</div>
        <div class="card-body">
            <div class="row g-3">
                @foreach (var k in (IEnumerable<dynamic>)ViewBag.LimitDurumu)
                {
                    string renk = k.Oran >= 100 ? "danger" : k.Oran >= 75 ? "warning" : "success";
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between mb-1" style="font-size:12.5px">
                            <span class="fw-semibold">@k.Ad</span>
                            <span class="text-muted">
                                @(((decimal)k.Harcanan).ToString("C0", tr))
                                <span class="text-muted">/</span>
                                @(((decimal)k.Limit).ToString("C0", tr))
                                @if (k.Oran >= 100) { <text><span class="badge bg-danger ms-1" style="font-size:10px">Aşıldı</span></text> }
                                else if (k.Oran >= 75) { <text><span class="badge bg-warning text-dark ms-1" style="font-size:10px">Dikkat</span></text> }
                            </span>
                        </div>
                        <div class="progress" style="height:6px">
                            <div class="progress-bar bg-@renk" style="width:@(k.Oran)%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    Chart.defaults.font.family = 'Inter, system-ui, sans-serif';
    Chart.defaults.font.size = 12;

    const trendData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AylikOzet));
    new Chart(document.getElementById('trendChart'), {
        type: 'bar',
        data: {
            labels: trendData.map(d => d.Etiket),
            datasets: [
                { label: 'Gelir', data: trendData.map(d => d.Gelir), backgroundColor: 'rgba(16,185,129,.8)', borderRadius: 6, borderSkipped: false },
                { label: 'Harcama', data: trendData.map(d => d.Harcama), backgroundColor: 'rgba(239,68,68,.8)', borderRadius: 6, borderSkipped: false }
            ]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'top', labels: { boxWidth: 10, padding: 16 } } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { callback: v => '₺' + (v/1000).toFixed(0) + 'K', color: '#94a3b8' } },
                x: { grid: { display: false }, ticks: { color: '#94a3b8' } }
            }
        }
    });

    @if (katVar) {
        <text>
        const pieData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.KategoriHarcama));
        new Chart(document.getElementById('pieChart'), {
            type: 'doughnut',
            data: {
                labels: pieData.map(d => d.Ad),
                datasets: [{ data: pieData.map(d => d.Toplam),
                    backgroundColor: ['#6366f1','#10b981','#f59e0b','#ef4444','#0ea5e9','#8b5cf6','#f97316','#14b8a6'],
                    borderWidth: 0, hoverOffset: 4 }]
            },
            options: {
                cutout: '68%',
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 10, padding: 12, font: { size: 11 } } },
                    tooltip: { callbacks: { label: ctx => ' ₺' + ctx.parsed.toLocaleString('tr-TR') } }
                }
            }
        });
        </text>
    }
</script>
}
