@model BudgetApp.Models.Gelir
@{
    ViewData["Title"] = "Gelir Ekle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0 fw-semibold"><i class="bi bi-plus-circle text-success me-2"></i>Gelir Ekle</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Açıklama" class="form-label fw-medium"></label>
                            <input asp-for="Açıklama" class="form-control" placeholder="Örn: Haziran maaşı" />
                            <span asp-validation-for="Açıklama" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Miktar" class="form-label fw-medium"></label>
                            <div class="input-group">
                                <input asp-for="Miktar" class="form-control" type="number" step="0.01" min="0.01" placeholder="0.00" />
                                <span class="input-group-text">₺</span>
                            </div>
                            <span asp-validation-for="Miktar" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Tarih" class="form-label fw-medium"></label>
                            <input asp-for="Tarih" class="form-control" type="date" />
                            <span asp-validation-for="Tarih" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Tip" class="form-label fw-medium"></label>
                            <select asp-for="Tip" class="form-select"
                                asp-items="Html.GetEnumSelectList<BudgetApp.Models.GelirTipi>()">
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Kaydet</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
