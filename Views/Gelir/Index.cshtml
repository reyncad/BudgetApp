@model IEnumerable<BudgetApp.Models.Gelir>
@{
    ViewData["Title"] = "Gelirler";
    var tr = new System.Globalization.CultureInfo("tr-TR");
    int ay  = ViewBag.SecilenAy;
    int yil = ViewBag.SecilenYil;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-semibold"><i class="bi bi-arrow-down-circle text-success me-2"></i>Gelirler</h4>
        <div class="d-flex gap-2">
            <form method="get" class="d-flex gap-2">
                <select name="ay" class="form-select form-select-sm" style="width:130px" onchange="this.form.submit()">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == ay)">
                            @(new DateTime(2000, m, 1).ToString("MMMM", new System.Globalization.CultureInfo("tr-TR")))
                        </option>
                    }
                </select>
                <select name="yil" class="form-select form-select-sm" style="width:90px" onchange="this.form.submit()">
                    @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
                    {
                        <option value="@y" selected="@(y == yil)">@y</option>
                    }
                </select>
            </form>
            <a asp-action="Create" class="btn btn-success btn-sm">
                <i class="bi bi-plus-lg"></i> Gelir Ekle
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2 px-4 d-flex justify-content-between align-items-center bg-success bg-opacity-10 rounded">
            <span class="fw-medium">Bu Ay Toplam Gelir</span>
            <span class="fs-5 fw-bold text-success">@(((decimal)ViewBag.Toplam).ToString("C2", tr))</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    Bu ay gelir kaydı yok.
                    <div class="mt-2"><a asp-action="Create" class="btn btn-sm btn-outline-success">Gelir Ekle</a></div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tarih</th>
                                <th>Açıklama</th>
                                <th>Tip</th>
                                <th class="text-end">Miktar</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var g in Model)
                            {
                                <tr>
                                    <td>@g.Tarih.ToString("dd.MM.yyyy")</td>
                                    <td>@g.Açıklama</td>
                                    <td>
                                        @{
                                            string tipRenk = g.Tip switch {
                                                BudgetApp.Models.GelirTipi.Maas => "primary",
                                                BudgetApp.Models.GelirTipi.Freelance => "info",
                                                BudgetApp.Models.GelirTipi.KiraGeliri => "warning",
                                                BudgetApp.Models.GelirTipi.Yatirim => "purple",
                                                _ => "secondary"
                                            };
                                        }
                                        <span class="badge bg-@tipRenk text-@(tipRenk == "warning" ? "dark" : "white")">
                                            @(g.Tip switch {
                                                BudgetApp.Models.GelirTipi.Maas => "Maaş",
                                                BudgetApp.Models.GelirTipi.Freelance => "Freelance",
                                                BudgetApp.Models.GelirTipi.KiraGeliri => "Kira Geliri",
                                                BudgetApp.Models.GelirTipi.Yatirim => "Yatırım",
                                                _ => "Diğer"
                                            })
                                        </span>
                                    </td>
                                    <td class="text-end fw-bold text-success">@(g.Miktar.ToString("C2", tr))</td>
                                    <td class="text-center">
                                        <a asp-action="Edit" asp-route-id="@g.Id" class="btn btn-sm btn-outline-primary me-1">Düzenle</a>
                                        <a asp-action="Delete" asp-route-id="@g.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
